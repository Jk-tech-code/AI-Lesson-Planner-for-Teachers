# ============================================================================
# AI Lesson Planner — Environment Variables
# Copy this to .env and fill in your values
# ============================================================================

# ---------- Database ----------
# PostgreSQL connection string (Supabase, RDS, etc.)
DATABASE_URL=postgresql://postgres:password@db.example.com:5432/postgres

# ---------- Authentication (NextAuth) ----------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
NEXTAUTH_URL=https://your-domain.com

# ---------- AI ----------
# OpenAI API key for AI content generation
OPENAI_API_KEY=sk-proj-your-key-here

# ---------- Email ----------
# Resend API key for transactional emails (welcome, password reset)
RESEND_API_KEY=re_your-resend-key

# ---------- App URL ----------
# Public URL of the deployed app (used in emails, redirects, OG images)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ---------- Stripe (optional — leave blank to disable payments) ----------
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs for each subscription tier
NEXT_PUBLIC_STRIPE_FREE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PROFESSIONAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_PROFESSIONAL_YEARLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_SCHOOL_PRICE_ID=
NEXT_PUBLIC_STRIPE_SCHOOL_YEARLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=
NEXT_PUBLIC_STRIPE_ENTERPRISE_YEARLY_PRICE_ID=
